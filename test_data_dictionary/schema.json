      },
      "major_version": {
        "description": "The number identifying the major version.\n",
        "type": "integer"
      },
      "minor_version": {
        "description": "The number identifying the minor version.\n",
        "type": "integer"
      },
      "release_date": {
        "oneOf": [
          {
            "type": "string",
            "format": "date-time"
          },
          {
            "type": "null"
          }
        ],
        "term": {
          "description": "A combination of date and time of day in the form [-]CCYY-MM-DDThh:mm:ss[Z|(+|-)hh:mm]\n"
        }
      },
      "released": {
